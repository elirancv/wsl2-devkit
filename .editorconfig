root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# PowerShell scripts conventionally use 4-space indents
[*.ps1]
indent_size = 4

# Shell scripts: 4 spaces, keep LF (they run in WSL)
[*.sh]
indent_size = 4

[Makefile]
indent_style = tab

[*.md]
trim_trailing_whitespace = false
